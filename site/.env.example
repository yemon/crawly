# Copy to .env.local before running. All values here are optional; the site
# builds and runs without them.

# Public site URL used by canonical/OG. Leave unset in dev to fall back to
# https://crawly.site (from lib/site.ts).
# NEXT_PUBLIC_SITE_URL=https://crawly.site

# Search-engine verification tokens. Add to app/layout.tsx `verification` field
# once you register the domain.
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=
