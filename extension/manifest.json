{
  "manifest_version": 3,
  "name": "Crawly",
  "version": "1.4.0",
  "description": "Record and replay UI tests: a comic spider types character-by-character, clicks buttons, yells KPOW when it passes.",
  "homepage_url": "https://crawly.site",
  "permissions": ["storage", "activeTab", "scripting"],
  "optional_host_permissions": ["*://*/*"],
  "background": { "service_worker": "bg.js" },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["*://*/*"]
    }
  ]
}
